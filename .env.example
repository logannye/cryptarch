# cryptarch configuration. Copy to .env and fill in.

# ── Exchange credentials (read-only first, write later) ───────────
# Until you set ENABLE_LIVE_ORDERS=true, these are not used for placement.
# Kraken — US-legal venue with both spot AND perpetual futures.
# Default DEFAULT_PAIRS in l1_executor.py uses Kraken.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Binance/Bybit/OKX — geo-blocked from the US without VPN.
# Empty by default; populate only if you're in a permitted region.
BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

COINBASE_API_KEY=
COINBASE_API_SECRET=

DERIBIT_API_KEY=
DERIBIT_API_SECRET=

# ── Storage ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost/cryptarch

# ── Master safety switch ──────────────────────────────────────────
# Hard gate: bot will refuse to submit live orders unless this is true.
# Default false → dry-run mode (uses real prices but does not place orders).
ENABLE_LIVE_ORDERS=false

# Per-strategy enables (independent of ENABLE_LIVE_ORDERS).
LAYER_1_FUNDING_ARB_ENABLED=true
LAYER_2_CASCADE_CAPTURE_ENABLED=false
LAYER_3_TAIL_HEDGE_ENABLED=false

# ── Bankroll & capital allocation ─────────────────────────────────
BANKROLL_USD=2000.0
ALLOC_LAYER_1_PCT=0.60          # 60% to funding arb
ALLOC_LAYER_2_PCT=0.25          # 25% to cascade capture
ALLOC_LAYER_3_PCT=0.15          # 15% to tail hedge

# ── Hard caps (enforced at order-submit time) ─────────────────────
MAX_TOTAL_DEPLOYED_PCT=0.50     # never more than 50% of bankroll at risk
MAX_PER_POSITION_USD=500.0      # cap on a single position size

# ── Layer 1 (funding arb) ─────────────────────────────────────────
L1_MIN_FUNDING_RATE_8H=0.0003   # 0.03% per 8h = ~33% APY before fees
L1_MIN_BASIS_PCT=0.001          # min perp/spot basis to bother
L1_MAX_BASIS_PCT=0.020          # don't enter if basis is already extreme

# ── Layer 2 (cascade capture) ────────────────────────────────────
L2_LADDER_LEVELS=4              # 1%, 2%, 3%, 4% below spot
L2_LADDER_TOTAL_USD=200.0       # total notional spread across ladder
L2_TAKE_PROFIT_PCT=0.012        # exit on +1.2% bounce after fill
L2_STOP_LOSS_PCT=0.030          # cut if cascade extends 3% past fill

# ── Layer 3 (tail hedge) ─────────────────────────────────────────
L3_DAILY_THETA_BUDGET_USD=10.0  # max premium burn per day
L3_TARGET_DAYS_TO_EXPIRY=45     # roll positions when DTE < 30
L3_OTM_PCT=0.20                 # 20% out of the money for both legs

# ── Cadence ───────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=30        # main loop cadence
RECONCILE_INTERVAL_SECONDS=300  # nightly state reconciliation

# ── Alerts ────────────────────────────────────────────────────────
RESEND_API_KEY=
ALERT_EMAIL=
